# RunPod API Configuration
VITE_RUNPOD_API_KEY=your_runpod_api_key_here
VITE_RUNPOD_ENDPOINT_ID=your_runpod_endpoint_id_here
# Optional override if you want to bypass endpoint-id based URL construction
# VITE_RUNPOD_BASE_URL=https://your-endpoint.api.runpod.ai

# API Mode Configuration
# Set to 'true' to use local API (localhost:8000/generate) instead of RunPod
# Default: false (uses RunPod)
VITE_USE_LOCAL_API=false
